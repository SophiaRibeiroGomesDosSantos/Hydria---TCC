        <article class="footer-identity-block">
            <figure class="brand-footer-wrapper">
                <img src="/images/logotipo.png" alt="Logotipo Hydria">
                <figcaption>HYDRIA</figcaption>
            </figure>
            
            <nav class="footer-social-media" aria-label="Redes sociais corporativas">
                <a href="#" aria-label="Twitter"><i class="fa-brands fa-twitter"></i></a>
