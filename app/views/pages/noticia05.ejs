                  <span class="search-bg">
                      <i class="fas fa-search" aria-hidden="true"></i>
                  </span>
              </a>
          </li>
          <li>
              <a href="/contato">
                  <i class="fas fa-comment-dots" aria-hidden="true"></i>
                  <span>Contato</span>
              </a>
          </li>
          <li>
              <a href="/sobre">
                  <i class="fas fa-users" aria-hidden="true"></i>
                  <span>Sobre</span>
              </a>
          </li>
      </ul>
